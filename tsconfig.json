{
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "incremental": true,
    "module": "esnext",
    "esModuleInterop": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "target": "ES2017"
  },
  "include": [
    "next-env.d.ts",
    ".next/types/**/*.ts",
    "**/*.ts",
    "**/*.tsx",
    "lib/nextAuth.ts",
    "app/api/auth/[...nextauth]/route.ts",
    "app/api/sendEmail/route.js",
    "app/api/send-email/route.js",
    "app/layout.js",
    "app/Edit/UpdateProfileForm.jsx",
    "app/Edit/ArrayFieldEditor.jsx",
    "app/Edit/EducationEditor.jsx",
    "app/Edit/ExperienceEditor.jsx",
    "app/Edit/ProjectsEditor.jsx",
    "app/(me)/UserProfileDisplay.jsx",
    "app/components/themes/theme-two.jsx",
    "app/components/themes/theme-five.jsx",
    "app/update-profilee/components/theme-provider.jsx",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
